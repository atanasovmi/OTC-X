# Git / GitHub
.git/
.github/
.gitignore
.gitattributes

# Python tooling
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Virtual environments
.venv/
venv/
env/
ENV/

# Dev requirements file — runtime image only needs requirements.txt
requirements-dev.txt

# IDE / editor / OS
.idea/
.vscode/
.claude/
.DS_Store
*.swp
*.swo
*.tmp
*.bak
*.orig

# Local dev tooling
node_modules/
package.json
package-lock.json
.playwright-mcp/
full-project-review/

# Build / dist
build/
dist/
*.egg
*.spec

# Logs
*.log
backend/logs/

# Tests and docs — not needed at runtime
tests/
docs/

# Raw per-ISIN trade CSVs (kept only for pipeline runs, ~250 files)
# The consolidated parquet snapshots in backend/data/ are what the
# dashboard actually reads, so the trades/ directory is excluded.
backend/data/trades/

# README / licence at root (not used by the running app)
README.md
LICENSE.md
SECURITY.md

# Jupyter / notebooks
*.ipynb
.ipynb_checkpoints/

# Secrets — anything that smells like a credential must never enter the build context
.env
.env.*
.envrc
*.pem
*.key
*.crt
*.csr
*.pfx
*.p12
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
id_ecdsa
id_ecdsa.*
*.token
*credentials*
*secret*

# Misc
*.png
*.jpg
*.pdf
# NOTE: Dockerfile and .dockerignore themselves are intentionally not
# excluded — modern buildkit needs them inside the build context.
